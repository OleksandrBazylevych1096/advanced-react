{
    "name": "advanced-react",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "lint:ts": "tsc -b",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "lint:scss": "stylelint **/*.scss",
        "lint:scss:fix": "stylelint **/*.scss --fix",
        "lint:arch": "npx steiger ./src",
        "lint:arch:fix": "npx steiger ./src --fix",
        "format:fix": "prettier . --write",
        "format": "prettier . --check",
        "check:all": "npm run lint:ts && npm run lint && npm run lint:scss && npm run format && npm run lint:arch && npm run test:unit",
        "check:all:fix": "npm run lint:ts && npm run lint:fix && npm run lint:scss:fix && npm run format:fix && npm run lint:arch:fix && npm run test:unit",
        "preview": "vite preview",
        "test:unit": "vitest",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:headed": "playwright test --headed",
        "test:e2e:debug": "playwright test --debug",
        "test:regression": "npx chromatic",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "prepare": "husky"
    },
    "dependencies": {
        "@hookform/resolvers": "^5.2.2",
        "@reduxjs/toolkit": "^2.8.2",
        "@testing-library/jest-dom": "^6.6.4",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^24.1.0",
        "axios": "^1.11.0",
        "embla-carousel-auto-scroll": "^8.6.0",
        "embla-carousel-react": "^8.6.0",
        "i18next": "^25.3.2",
        "i18next-browser-languagedetector": "^8.2.0",
        "i18next-http-backend": "^3.0.2",
        "leaflet": "^1.9.4",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "react-hook-form": "^7.71.2",
        "react-i18next": "^15.6.1",
        "react-international-phone": "^4.6.0",
        "react-leaflet": "^5.0.0",
        "react-redux": "^9.2.0",
        "react-router": "^7.7.1",
        "react-virtualized": "^9.22.6",
        "redux-persist": "^6.0.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@chromatic-com/storybook": "^4.1.0",
        "@conarti/eslint-plugin-feature-sliced": "^1.0.5",
        "@eslint/js": "^9.30.1",
        "@feature-sliced/steiger-plugin": "^0.5.7",
        "@playwright/test": "^1.59.1",
        "@storybook/addon-a11y": "^9.1.0",
        "@storybook/addon-docs": "^9.1.0",
        "@storybook/addon-vitest": "^9.1.0",
        "@storybook/react-vite": "^9.1.0",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@types/leaflet": "^1.9.21",
        "@types/react": "^19.1.8",
        "@types/react-dom": "^19.1.6",
        "@types/react-virtualized": "^9.22.3",
        "@vitejs/plugin-react": "^4.6.0",
        "@vitest/browser": "3.2.4",
        "@vitest/coverage-v8": "3.2.4",
        "chromatic": "^13.1.3",
        "eslint": "^9.30.1",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.20",
        "eslint-plugin-storybook": "^9.1.0",
        "globals": "^16.3.0",
        "husky": "^9.1.7",
        "jsdom": "^26.1.0",
        "msw": "^2.12.7",
        "msw-storybook-addon": "^2.0.6",
        "playwright": "^1.54.2",
        "prettier": "^3.6.2",
        "sass-embedded": "^1.89.2",
        "steiger": "^0.5.11",
        "storybook": "^9.1.0",
        "stylelint": "^16.23.0",
        "stylelint-config-standard-scss": "^15.0.1",
        "typescript": "~5.8.3",
        "typescript-eslint": "^8.35.1",
        "vite": "^7.0.4",
        "vite-plugin-svgr": "^4.3.0",
        "vitest": "^3.2.4"
    },
    "msw": {
        "workerDirectory": [
            "public"
        ]
    }
}
